# Cloud backend configuration example
#
# Cloud/server development is paused while the desktop-first release is being
# stabilized. Keep real credentials only in a local .env file and never commit
# them to the repository.

# Port for the server to run on
PORT=3001

# PostgreSQL Database Connection URL
DATABASE_URL=postgresql://user:password@host:5432/database

# TimeWebCloud API URL
TIMEWEB_API_URL=http://localhost:3001/api

# Firebase Admin SDK configuration as a base64 encoded service account JSON.
# Use a local .env file for real service account data.
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
